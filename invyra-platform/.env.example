# Invyra Platform Wave 5 Phase 1J
# Copy this file to .env before running the platform app.

# PostgreSQL is the target database for the operational SaaS platform foundation.
DATABASE_URL="postgresql://invyra:invyra_dev_password@localhost:5432/invyra_platform?schema=public"

# Change these before production use.
INVYRA_SESSION_COOKIE="invyra_session"
INVYRA_SESSION_DAYS="7"
INVYRA_PASSWORD_PEPPER="replace-with-long-random-server-secret"
INVYRA_APP_URL="http://localhost:3000"
INVYRA_DEVICE_CODE_HOURS="24"

# Development seed password for all seeded users.
INVYRA_SEED_PASSWORD="InvyraDemo#2026!"

# Default environment context for local development.
INVYRA_DEFAULT_ENVIRONMENT="LIVE"

# Runtime verification toggles.
INVYRA_DEMO_ORGANISATION_ID="invyra_demo_organisation"
INVYRA_DEMO_LICENSE_ID="invyra_demo_platform_license"

# Phase 1I local install doctor checks.
SESSION_SECRET="replace-with-a-long-random-session-secret"
INVYRA_PLATFORM_ENV="development"
